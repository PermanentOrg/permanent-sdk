{
	"extends": "@tsconfig/esm/tsconfig.json",
	"compilerOptions": {
		"module": "esnext",
		"rootDir": "src",
		"outDir": "dist/esm",
		"declaration": true,
		"strictNullChecks": true,
		"allowSyntheticDefaultImports": true,
		"types": ["node"]
	},
	"include": ["src/**/*"],
	"exclude": ["**/*.test.ts", "**/__tests__/**"]
}
